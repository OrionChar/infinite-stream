{
  "compilerOptions": {
    // "strictNullChecks": true,
    "target": "es2022",
    "module": "nodenext",
    "lib": ["ES2022"],
    "moduleResolution": "nodenext",
    "rootDir": "src",
    "outDir": "build",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "alwaysStrict": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitAny": false,
    "noImplicitThis": false,
    "strictNullChecks": false,
    "skipLibCheck": true,
  },
  "exclude": [],
  "include": ["src", "env.d.ts", "src/__tests__", "eslint.config.mjs", "tsconfig.release.json", "tsconfig.vitest.json", "tsconfig.eslint.json"]
}
